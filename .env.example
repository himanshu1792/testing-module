# ─── Database (Postgres on a separate host) ───────────────────────────────
# Used by both the Next.js app and the worker. The worker also uses it as the
# task queue (SELECT ... FOR UPDATE SKIP LOCKED).
DATABASE_URL="postgresql://user:password@db-host:5432/headless_testforge?schema=public"

# ─── Credential encryption (AES-256-GCM) ──────────────────────────────────
# 32-byte key as 64 hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── AI provider ───────────────────────────────────────────────────────────
# "openai" (direct) or "azureopenai" (Azure OpenAI behind a WSO2 gateway)
AI_PROVIDER="openai"

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Azure OpenAI via WSO2 (when AI_PROVIDER=azureopenai)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_CHAT_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2024-08-01-preview"
WSO2_TOKEN_URL=""
WSO2_CONSUMER_KEY=""
WSO2_CONSUMER_SECRET=""
# Dev-only escape hatch for self-signed corporate gateways. Prefer NODE_EXTRA_CA_CERTS.
WSO2_ALLOW_SELF_SIGNED_CERTS="false"

# ─── Worker tuning ─────────────────────────────────────────────────────────
# Max pipelines running at once in a single worker process (concurrency cap).
WORKER_CONCURRENCY="3"
# How often the worker polls the queue for new work, in milliseconds.
POLL_INTERVAL_MS="10000"
# Stable id for this worker (used in task lock rows). Defaults to hostname:pid.
WORKER_ID=""
# A running task whose lock is older than this is considered crashed and requeued.
STALE_CLAIM_TIMEOUT_MS="900000"
# How many times a task is retried before it is marked failed.
MAX_TASK_ATTEMPTS="2"
# Skip claiming new work when free system memory drops below this (MB). 0 = disabled.
MEM_FREE_FLOOR_MB="1024"
